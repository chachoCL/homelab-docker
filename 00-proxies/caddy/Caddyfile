					session_duration 10m
					dynamic {
						display_name kaneo
						show_details true
						theme ghost
						refresh_frequency 2s
					}
				}
				reverse_proxy kaneo-api-1:1337
			}
		}
		handle {
			route {
				sablier http://sablier:10000 {
					group kaneo
					session_duration 10m
