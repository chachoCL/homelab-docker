{
	admin 0.0.0.0:2019
}

*.joseluna.dev {
	tls {
		dns cloudflare {env.CF_API_TOKEN}
		propagation_delay 2m
		resolvers 1.1.1.1
	}

	@caddy host caddy.joseluna.dev
	handle @caddy {
		root * /usr/share/caddy
		file_server
	}

	@dispatcharr host dispatcharr.joseluna.dev
	handle @dispatcharr {
		route {
			reverse_proxy dispatcharr:9191
		}
	}

	@openclaw host openclaw.joseluna.dev
	handle @openclaw {
		reverse_proxy http://10.0.0.33:18789 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
		}
	}

	@noco-db host notion.joseluna.dev
	handle @noco-db {
		route {
			sablier http://sablier:10000 {
				group noco-db
				session_duration 10m
				dynamic {
					display_name NocoDB
					show_details true
					theme ghost
					refresh_frequency 2s
				}
			}
			reverse_proxy noco-db:8080
		}
	}

	@kaneo host kaneo.joseluna.dev
	handle @kaneo {
		handle /api/* {
