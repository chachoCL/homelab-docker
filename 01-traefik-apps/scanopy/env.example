SCANOPY_DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/scanopy
SCANOPY_WEB_EXTERNAL_PATH="/app/static"
SCANOPY_PUBLIC_URL=https://scanopy.example.com
SCANOPY_SERVER_PORT=60072
SCANOPY_LOG_LEVEL=info
SCANOPY_INTEGRATED_DAEMON_URL=http://127.0.0.1:60073
# SCANOPY_DISABLE_REGISTRATION=true

SCANOPY_USE_SECURE_SESSION_COOKIES=true

SCANOPY_SMTP_RELAY=mail.example.com:465
SCANOPY_SMTP_USERNAME=no-reply@example.com
SCANOPY_SMTP_PASSWORD=CHANGE_ME
SCANOPY_SMTP_EMAIL=no-reply@example.com

SCANOPY_SERVER_URL=http://127.0.0.1:60072
SCANOPY_DAEMON_PORT=60073
SCANOPY_BIND_ADDRESS=0.0.0.0
SCANOPY_NAME="scanopy-daemon"
SCANOPY_MODE="Push"

# SCANOPY_DAEMON_API_KEY=<autogenerated>

SCANOPY_HEARTBEAT_INTERVAL=30
